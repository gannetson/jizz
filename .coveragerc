[run]
source = jizz,compare,media
omit =
    */migrations/*
    */tests/*
    */test_*.py
    */__pycache__/*
    */venv/*
    */.virtualenvs/*
    manage.py
    */wsgi.py
    */scrapers/*
    *scraper*.py
    */management/commands/*scrape*.py
    */management/commands/provision_country_species_frequency.py
    */management/commands/daily_challenge_reminders.py
    */management/commands/daily_challenge_end_series.py
    */management/commands/daily_challenge_all_answered.py
    *standardize_copyright*
    *generate_comparison*
    *ai_service*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if TYPE_CHECKING:
    if __name__ == .__main__.:

[html]
directory = htmlcov
