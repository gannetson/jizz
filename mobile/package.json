{
  "name": "birdr-mobile",
  "version": "1.35.0",
  "main": "node_modules/expo/AppEntry.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "postinstall": "node -e \"var v=parseInt(process.version.slice(1).split('.')[0],10); if(v>=18) require('child_process').execSync('npx patch-package', {stdio:'inherit'});\"",
    "build:ios": "eas build --platform ios --profile production",
    "push:ios": "eas submit --platform ios --profile production --latest",
    "build:ios:push": "eas build --platform ios --profile production --non-interactive && eas submit --platform ios --profile production --latest --non-interactive",
    "build:android": "eas build --platform android --profile production --local",
    "build:android:cloud": "eas build --platform android --profile production",
    "push:android": "eas submit --platform android --profile production --latest",
    "build:android:push": "eas build --platform android --profile production --local --non-interactive && eas submit --platform android --profile production --latest --non-interactive",
    "build:android:debug": "cd android && ./run-with-node22.sh app:assembleDebug -x lint -x test",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "build:android:aab": "cd android && ./gradlew bundleRelease",
    "print-sha1": "cd android && ./gradlew signingReport",
    "make-icon": "node scripts/make-icon-transparent.cjs",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/drawer": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "^54",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-clipboard": "~8.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-autocomplete-dropdown": "^4.4.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "^15.0.0",
    "@react-native-community/cli-platform-android": "^15.0.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "expo-font": "~14.0.11",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-video",
          "expo-audio"
        ]
      }
    }
  },
  "private": true
}
