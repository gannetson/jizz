{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2"
      },
      "android": {
        "credentialsSource": "local"
      }
    },
    "production": {
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2",
        "autoIncrement": true
      },
      "android": {
        "credentialsSource": "local"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
