{
  "expo": {
    "name": "Birdr",
    "slug": "birdr",
    "scheme": "birdr",
    "version": "1.71.0",
    "buildNumber": "71",
    "releaseCodename": "Grey Partridge",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2D5A3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pro.birdr.app",
      "usesAppleSignIn": true,
      "icon": "./assets/icon.png",
      "associatedDomains": [
        "applinks:birdr.pro"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "pro.birdr.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "birdr.pro",
              "pathPrefix": "/join/"
            },
            {
              "scheme": "https",
              "host": "birdr.pro",
              "pathPrefix": "/join/challenge/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "./plugins/withAndroid16Kb.js",
      "expo-dev-client",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Birdr needs access to your photo library to set your profile picture.",
          "cameraPermission": "Birdr needs access to your camera to take a profile picture."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.56451813101-kkjv7e0agsujmmtuuq5gs6mdkumdmp71"
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2D5A3D",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b41359de-e747-4acd-b200-b7d8bb9520a5"
      },
      "appStoreId": ""
    }
  }
}
